# Infrastructure
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=dupi_rag
POSTGRES_USER=dupi
# Generate a strong value before shared or deployed use:
#   openssl rand -base64 32
POSTGRES_PASSWORD=change-me-generate-random-postgres-password

REDIS_HOST=redis
REDIS_PORT=6379

MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=dupi_chunks

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change-me-generate-random-minio-access-key
MINIO_SECRET_KEY=change-me-generate-random-minio-secret-key
MINIO_BUCKET=dupi-documents

# Security
# Leave blank only for trusted local development.
# Generate non-empty values for shared or deployed environments:
#   openssl rand -base64 32
DUPI_API_KEY=
DUPI_INTERNAL_KEY=
DUPI_AUTH_SECRET=
DUPI_AUTH_TOKEN_TTL_SECONDS=28800
DUPI_AUTH_LOGIN_MAX_FAILURES=5
DUPI_AUTH_LOGIN_LOCKOUT_SECONDS=300
# Optional built-in accounts. Keep commented to preserve trusted local open mode.
# When any account is configured, browser login uses HttpOnly DUPI_AUTH cookie
# plus CSRF header for mutating requests. Bearer token and compatibility
# DUPI_API_KEY remain available for scripts and trusted deployment paths.
# DUPI_SECURITY_USERS_0_USERNAME=admin
# Prefer PASSWORD_HASH in shared/deployed environments. Plain PASSWORD is kept for
# trusted local bootstrap only. Format: pbkdf2$iterations$base64url-salt$base64url-hash
# DUPI_SECURITY_USERS_0_PASSWORD_HASH=pbkdf2$120000$base64url-salt$base64url-hash
# DUPI_SECURITY_USERS_0_PASSWORD=change-me-admin-password
# DUPI_SECURITY_USERS_0_TENANT_ID=default
# DUPI_SECURITY_USERS_0_ROLE=ADMIN
# DUPI_SECURITY_USERS_0_PERMISSIONS=*
# Optional comma-separated knowledge base ids for resource-level access control.
# Empty or * means the account can access all knowledge bases permitted by role/permissions.
# DUPI_SECURITY_USERS_0_KNOWLEDGE_BASE_IDS=*
# DUPI_SECURITY_USERS_0_TOKEN_VERSION=1

# Upload protection
UPLOAD_RATE_LIMIT_ENABLED=true
UPLOAD_RATE_LIMIT_REQUESTS=20
UPLOAD_RATE_LIMIT_WINDOW_SECONDS=60
INGEST_QUEUE_MAX_PENDING_JOBS=200
INGEST_RECOVERY_CRON=0 */2 * * * *
INGEST_RECOVERY_MAX_ATTEMPTS=3
INGEST_OUTBOX_DISPATCH_CRON=*/10 * * * * *

# Background cleanup
ORPHAN_VECTOR_CLEANUP_CRON=0 30 3 * * *

# Audit operations
AUDIT_RETENTION_DAYS=180
AUDIT_RETENTION_CRON=0 15 2 * * *
AUDIT_ALERT_WINDOW_MINUTES=30
AUDIT_ALERT_FAILED_THRESHOLD=10
AUDIT_ALERT_WEBHOOK_URL=
AUDIT_ALERT_WEBHOOK_TIMEOUT_SECONDS=10

# Chat LLM (DeepSeek official API — no /embeddings endpoint)
CHAT_BASE_URL=https://api.deepseek.com
CHAT_API_KEY=sk-your-deepseek-key-here
CHAT_MODEL=deepseek-chat

# Embedding (智谱 AI — https://open.bigmodel.cn)
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_API_KEY=your-zhipu-api-key-here
EMBEDDING_MODEL=embedding-2
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32

# Legacy fallbacks (used when CHAT_* / EMBEDDING_* are empty)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_DIMENSION=

# Internal
API_BASE_URL=http://api:8080
WORKER_BASE_URL=http://worker:8000
