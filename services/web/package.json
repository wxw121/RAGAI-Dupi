{
  "name": "dupi-rag-web",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "node --require ./scripts/node16-webcrypto.cjs ./node_modules/vite/bin/vite.js",
    "build": "tsc -b && node --require ./scripts/node16-webcrypto.cjs ./node_modules/vite/bin/vite.js build",
    "preview": "node --require ./scripts/node16-webcrypto.cjs ./node_modules/vite/bin/vite.js preview",
    "test": "node --require ./scripts/node16-webcrypto.cjs ./node_modules/vitest/vitest.mjs run",
    "coverage": "node --require ./scripts/node16-webcrypto.cjs ./node_modules/vitest/vitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12",
    "vitest": "^1.6.0"
  }
}
